---
import Layout from "../layouts/Layout.astro";
import {
	getArtistesAlpha,
	getScenesByName,
	pb,
} from "../../backend/backend.mjs";

const artistes = await getArtistesAlpha();
const scenes = await getScenesByName();

const sceneArtistOrder = {
	"scène découverte": [
		"j8nriyucmzjtkim",
		"k3je02zet3l6omq",
		"tvwnq35rr932rcr",
		"iq6z8renidcpc7t",
	],
	"grande scène": [
		"x9be9qq8r4wrgml",
		"5ddozlisgqo03jc",
		"bw4hcnx9yz81hra",
		"nm8abdkh6pknuw6",
	],
};

function normalizeSceneName(sceneName) {
	return (sceneName || "").trim().toLowerCase();
}

function formatTimeLabel(value) {
	const date = new Date(value);

	if (Number.isNaN(date.getTime())) {
		return "--:--";
	}

	return new Intl.DateTimeFormat("fr-FR", {
		hour: "2-digit",
		minute: "2-digit",
	}).format(date);
}

const slotsByScene = scenes.reduce((acc, slot) => {
	const sceneName = slot.nom_scene || slot.scene || slot.nom || "";
	const key = normalizeSceneName(sceneName);

	if (!acc[key]) {
		acc[key] = [];
	}

	acc[key].push(slot.date_festival);
	return acc;
}, {});

for (const key of Object.keys(slotsByScene)) {
	slotsByScene[key].sort(
		(leftValue, rightValue) =>
			new Date(leftValue || 0).getTime() -
			new Date(rightValue || 0).getTime(),
	);
}

const preciseTimeByArtistId = {};

for (const [sceneKey, artistIds] of Object.entries(sceneArtistOrder)) {
	const slots = slotsByScene[sceneKey] || [];

	artistIds.forEach((artistId, index) => {
		const slotValue = slots[index];
		if (slotValue) {
			preciseTimeByArtistId[artistId] = formatTimeLabel(slotValue);
		}
	});
}
---

<Layout title="Artistes">
	<section class="artists-page">
		<h1>Artistes</h1>

		<div class="artists-list">
			{
				artistes.map((artiste) => {
					const photoField = artiste.photo_artiste || artiste.image;
					const imageUrl = photoField
						? pb.files.getURL(artiste, photoField)
						: "/hero_image_tap_dancer.jpg";
					const name =
						artiste.nom_prenom_pseudo_artiste ||
						artiste.nom ||
						artiste.name ||
						"Artiste";
					const genre = artiste.type_de_festival || "Tap";
					const horaire =
						preciseTimeByArtistId[artiste.id] ||
						artiste.horaire ||
						artiste.heure ||
						"--:--";
					const date =
						artiste.dateRepresentation ||
						artiste.date ||
						"06 juin 2025";
					const scene = artiste.nom_scene || "Scène Découverte";

					return (
						<a href={`/${artiste.id}`} class="artist-card-link">
							<article class="artist-card">
								<img src={imageUrl} alt={name} loading="lazy" />
								<div class="card-content">
									<h2>{name}</h2>
									<p class="genre">{genre}</p>
									<p>
										<strong>Horaire :</strong> {horaire}
									</p>
									<p>
										<strong>Date :</strong> {date}
									</p>
									<p>
										<strong>Scène :</strong> {scene}
									</p>
								</div>
							</article>
						</a>
					);
				})
			}
		</div>
	</section>
</Layout>

<style>
	.artists-page {
		max-width: 1100px;
		margin: 0 auto;
		padding: 1.4rem 0.45rem 2rem;
	}

	.artists-page h1 {
		margin: 0 0 0.8rem;
		font-family: "Ag Body", serif;
		font-size: clamp(2.4rem, 7.5vw, 4.2rem);
		line-height: 1;
		color: #9a6f29;
	}

	.artists-list {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.artist-card-link {
		display: block;
		text-decoration: none;
		color: inherit;
	}

	.artist-card {
		background: #1f2023;
		border-radius: 1.2rem;
		overflow: hidden;
		box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
		transition:
			transform 0.18s ease,
			box-shadow 0.18s ease;
	}

	.artist-card-link:hover .artist-card,
	.artist-card-link:focus-visible .artist-card {
		transform: translateY(-3px);
		box-shadow: 0 12px 22px rgba(0, 0, 0, 0.18);
	}

	.artist-card img {
		display: block;
		width: 100%;
		height: 210px;
		object-fit: cover;
	}

	.card-content {
		padding: 0.8rem 0.65rem 0.95rem;
	}

	.card-content h2 {
		margin: 0;
		font-family: "Ag Body", serif;
		font-size: clamp(1.55rem, 5.5vw, 2rem);
		line-height: 1.04;
		color: #a98034;
	}

	.card-content .genre {
		margin: 0.25rem 0 0.55rem;
		color: #8b2a1e;
		font-family: "Ag Body", serif;
		font-size: clamp(1rem, 3.5vw, 1.25rem);
		font-weight: 700;
	}

	.card-content p {
		margin: 0.2rem 0;
		color: #f0e3ce;
		font-family: "Ag Body", serif;
		font-size: clamp(0.95rem, 3.2vw, 1.16rem);
	}

	.card-content p strong {
		color: #a98034;
		font-weight: 700;
	}

	@media (min-width: 900px) {
		.artists-page {
			padding: 1.8rem 1.3rem 2.6rem;
		}

		.artists-list {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: 1.2rem;
		}

		.artist-card img {
			height: 250px;
		}
	}
</style>
