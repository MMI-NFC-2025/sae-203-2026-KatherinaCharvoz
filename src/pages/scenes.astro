---
import Layout from "../layouts/Layout.astro";
import { getScenesByName, pb } from "../../backend/backend.mjs";

type SceneSummaryRecord = {
    image_scene?: string;
    scene?: string;
    nom?: string;
    nom_scene?: string;
    [key: string]: unknown;
};

const preferredSceneOrder = ["Grande Scène", "Scène Découverte"];
const rawScenes = await getScenesByName();

function normalizeSceneName(sceneName: string) {
    return (sceneName || "")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .trim()
        .toLowerCase();
}

function slugifySceneName(sceneName: string) {
    return normalizeSceneName(sceneName)
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-|-$/g, "");
}

function getSceneImage(scene: SceneSummaryRecord) {
    if (scene.image_scene) {
        return pb.files.getURL(scene, scene.image_scene);
    }

    const normalizedName = normalizeSceneName(
        scene.scene || scene.nom || scene.nom_scene || "",
    );

    if (normalizedName.includes("grande")) {
        return "/programme_pageaccueil.jpg";
    }

    if (normalizedName.includes("decouverte")) {
        return "/artistes_pageaccueil.jpg";
    }

    return "/hero_image_tap_dancer.jpg";
}

function getSceneDescription(sceneName: string) {
    const normalizedName = normalizeSceneName(sceneName);

    if (normalizedName.includes("grande")) {
        return "Sous le grand chapiteau, juste au centre du festival.";
    }

    if (normalizedName.includes("decouverte")) {
        return "Vers la zone nord du festival, là où chaque pas réserve une surprise.";
    }

    return "Un espace pensé pour faire vibrer le public au rythme des performances.";
}

const scenes = Array.from(
    rawScenes
        .reduce((uniqueScenes, scene) => {
            const name = scene.scene || scene.nom || scene.nom_scene || "Scène";
            const key = normalizeSceneName(name);

            if (!uniqueScenes.has(key)) {
                uniqueScenes.set(key, {
                    id: slugifySceneName(name),
                    name,
                    record: scene,
                });
            }

            return uniqueScenes;
        }, new Map())
        .values(),
)
    .sort((leftScene, rightScene) => {
        const leftIndex = preferredSceneOrder.findIndex(
            (sceneName) =>
                normalizeSceneName(sceneName) ===
                normalizeSceneName(leftScene.name),
        );
        const rightIndex = preferredSceneOrder.findIndex(
            (sceneName) =>
                normalizeSceneName(sceneName) ===
                normalizeSceneName(rightScene.name),
        );

        return (
            (leftIndex === -1 ? Number.MAX_SAFE_INTEGER : leftIndex) -
            (rightIndex === -1 ? Number.MAX_SAFE_INTEGER : rightIndex)
        );
    })
    .slice(0, 2);
---

<Layout title="Scènes">
    <section class="scenes-page">
        <h1>Les Scènes</h1>

        <div class="scenes-list">
            {
                scenes.map((scene) => {
                    const imageUrl = getSceneImage(scene.record);
                    const description = getSceneDescription(scene.name);

                    return (
                        <a class="scene-card" href={`/scenes/${scene.id}`}>
                            <img
                                src={imageUrl}
                                alt={scene.name}
                                loading="lazy"
                            />
                            <div class="scene-content">
                                <h2>{scene.name}</h2>
                                <p>{description}</p>
                            </div>
                        </a>
                    );
                })
            }
        </div>
    </section>
</Layout>

<style>
    .scenes-page {
        max-width: 1100px;
        margin: 0 auto;
        padding: 1.4rem 0.45rem 2rem;
    }

    .scenes-page h1 {
        margin: 0 0 1rem;
        font-family: "Ag Body", serif;
        font-size: clamp(2.6rem, 8vw, 4.5rem);
        line-height: 1;
        color: #9a6f29;
    }

    .scenes-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1.15rem;
    }

    .scene-card {
        display: block;
        background: #1f2023;
        border-radius: 1.2rem;
        overflow: hidden;
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
        text-decoration: none;
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .scene-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 28px rgba(0, 0, 0, 0.18);
    }

    .scene-card img {
        display: block;
        width: 100%;
        height: 220px;
        object-fit: cover;
    }

    .scene-content {
        padding: 0.8rem 0.7rem 0.95rem;
    }

    .scene-content h2 {
        margin: 0 0 0.22rem;
        font-family: "Ag Body", serif;
        font-size: clamp(1.6rem, 5vw, 2.1rem);
        line-height: 1.05;
        color: #a98034;
    }

    .scene-content p {
        margin: 0;
        font-family: "Ag Body", serif;
        font-size: clamp(1rem, 3.2vw, 1.2rem);
        line-height: 1.35;
        color: #8b2a1e;
    }

    @media (min-width: 900px) {
        .scenes-page {
            padding: 1.8rem 1.3rem 2.6rem;
        }

        .scenes-list {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1.3rem;
        }

        .scene-card img {
            height: 280px;
        }
    }
</style>
