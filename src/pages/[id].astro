---
import Layout from "../layouts/Layout.astro";
import {
    getArtistesAlpha,
    getArtisteById,
    pb,
} from "../../backend/backend.mjs";
import { artistScheduleById } from "../data/artistSchedule";

export async function getStaticPaths() {
    const artistes = await getArtistesAlpha();

    return artistes.map((artiste) => ({
        params: { id: artiste.id },
    }));
}

const { id } = Astro.params;
const pocketBaseIdPattern = /^[a-z0-9]{15}$/i;
const isValidPocketBaseId =
    typeof id === "string" && pocketBaseIdPattern.test(id);

let artiste = null;

if (isValidPocketBaseId) {
    try {
        artiste = await getArtisteById(id);
    } catch (error: any) {
        if (error?.status !== 404) {
            throw error;
        }
    }
}

if (!artiste) {
    Astro.response.status = 404;
}
const preciseSchedule = artiste?.id ? artistScheduleById[artiste.id] : null;

const name =
    artiste?.nom_prenom_pseudo_artiste ||
    artiste?.nom ||
    artiste?.name ||
    "Artiste";
const genre = artiste?.type_de_festival || "Tap";
const description =
    artiste?.description ||
    "Artiste invité du Flying Tap Fest, découvrez son univers, son énergie et son style sur scène.";
const scene =
    preciseSchedule?.scene || artiste?.nom_scene || "Scène Découverte";
const date =
    preciseSchedule?.date ||
    artiste?.dateRepresentation ||
    artiste?.date ||
    "Date à confirmer";
const horaire =
    preciseSchedule?.horaire ||
    artiste?.horaire ||
    artiste?.heure ||
    "Horaire à confirmer";
const photoField = artiste?.photo_artiste || artiste?.image;
const heroImage =
    artiste && photoField
        ? pb.files.getURL(artiste, photoField)
        : "/hero_image_tap_dancer.jpg";
const galleryImages = [
    "/artistes_pageaccueil.jpg",
    "/programme_pageaccueil.jpg",
    "/hero_image_tap_dancer.jpg",
];
---

<Layout title={name}>
    <section class="artist-detail-page">
        {
            artiste ? (
                <>
                    <a href="/artistes" class="back-link">
                        &larr; Retour à la liste des artistes
                    </a>

                    <header class="artist-header">
                        <h1>{name}</h1>
                        <p class="artist-genre">{genre}</p>
                    </header>

                    <img src={heroImage} alt={name} class="artist-hero" />

                    <div class="artist-meta-grid">
                        <div class="meta-card">
                            <h2>Scène</h2>
                            <p>{scene}</p>
                        </div>
                        <div class="meta-card">
                            <h2>Date</h2>
                            <p>{date}</p>
                        </div>
                        <div class="meta-card">
                            <h2>Horaire</h2>
                            <p>{horaire}</p>
                        </div>
                    </div>

                    <section class="about-section">
                        <h2>À propos</h2>
                        <div class="about-card">
                            <p>{description}</p>
                        </div>
                    </section>

                    <section class="gallery-section">
                        <h2>Galerie Photos</h2>
                        <div class="gallery-grid">
                            {galleryImages.map((image, index) => (
                                <img
                                    src={image}
                                    alt={`${name} photo ${index + 1}`}
                                    loading="lazy"
                                />
                            ))}
                        </div>
                    </section>
                </>
            ) : (
                <section class="not-found-block">
                    <h1>Artiste introuvable</h1>
                    <p>Cette page n'existe pas ou a été déplacée.</p>
                    <a href="/artistes" class="back-link">
                        &larr; Retour à la liste des artistes
                    </a>
                </section>
            )
        }
    </section>
</Layout>

<style>
    .artist-detail-page {
        max-width: 760px;
        margin: 0 auto;
        padding: 1rem 0.35rem 2rem;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 0.9rem;
        color: #8e6b2d;
        text-decoration: none;
        font-family: "Ag Body", serif;
        font-size: 0.95rem;
    }

    .artist-header h1 {
        margin: 0;
        font-family: "Ag Body", serif;
        font-size: clamp(2.5rem, 8vw, 4.2rem);
        line-height: 1;
        color: #9a6f29;
    }

    .artist-genre {
        margin: 0.15rem 0 1rem;
        font-family: "Ag Body", serif;
        font-size: clamp(1.2rem, 3.5vw, 1.6rem);
        font-weight: 700;
        color: #8b271b;
    }

    .artist-hero {
        width: 100%;
        height: 360px;
        object-fit: cover;
        display: block;
        margin-bottom: 1rem;
    }

    .artist-meta-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.7rem;
        margin-bottom: 1.4rem;
    }

    .meta-card {
        background: #1f2023;
        border-radius: 0.95rem;
        padding: 0.85rem 0.9rem;
    }

    .meta-card h2 {
        margin: 0 0 0.2rem;
        font-family: "Ag Body", serif;
        font-size: 1rem;
        color: #a98034;
    }

    .meta-card p {
        margin: 0;
        color: #efe5d5;
        font-family: "Ag Body", serif;
    }

    .about-section h2,
    .gallery-section h2 {
        margin: 0 0 0.65rem;
        font-family: "Ag Body", serif;
        font-size: clamp(1.7rem, 5vw, 2.2rem);
        color: #7c2c1f;
    }

    .about-card {
        border: 1px solid #b6904f;
        padding: 0.8rem 0.85rem;
        background: rgba(255, 255, 255, 0.35);
        margin-bottom: 1.5rem;
    }

    .about-card p {
        margin: 0;
        color: #2e2a24;
        font-family: "Ag Body", serif;
        line-height: 1.45;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0.8rem;
    }

    .gallery-grid img {
        width: 100%;
        height: 150px;
        object-fit: cover;
        border-radius: 0.85rem;
        display: block;
    }

    .not-found-block h1 {
        margin: 0 0 0.5rem;
        font-family: "Ag Body", serif;
        color: #7a2018;
        font-size: clamp(2rem, 6vw, 3rem);
    }

    .not-found-block p {
        margin: 0 0 1rem;
        font-family: "Ag Body", serif;
        color: #2f2922;
    }

    @media (min-width: 900px) {
        .artist-detail-page {
            padding: 1.5rem 1rem 2.8rem;
        }

        .artist-hero {
            height: 520px;
        }

        .artist-meta-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .gallery-grid {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }
</style>
