---
import Layout from "../layouts/Layout.astro";

const contacts = [
    {
        icon: "✉",
        title: "Email",
        lines: ["contact@flyingtapfest.fr", "presse@flyingtapfest.fr"],
    },
    {
        icon: "☎",
        title: "Téléphone",
        lines: ["+33 1 23 45 67 89", "Lun-Ven: 9h-18h"],
    },
    {
        icon: "◎",
        title: "Adresse",
        lines: [
            "Flying Tap Fest",
            "123 Avenue des Claquettes",
            "25190 Pont-de-Roide, France",
        ],
    },
];
---

<Layout title="Contact">
    <section class="contact-page">
        <header class="contact-header">
            <h1>Contact</h1>
            <p>Envoyez-nous un message</p>
        </header>

        <form class="contact-form" method="post" action="#">
            <label for="full-name">Nom complet</label>
            <input
                id="full-name"
                name="fullName"
                type="text"
                placeholder="Votre nom"
            />

            <label for="email">Adresse email</label>
            <input
                id="email"
                name="email"
                type="email"
                placeholder="votre@email.com"
            />

            <label for="subject">Sujet</label>
            <input
                id="subject"
                name="subject"
                type="text"
                placeholder="Votre sujet"
            />

            <label for="message">Votre message</label>
            <textarea
                id="message"
                name="message"
                rows={5}
                placeholder="Ecrivez votre message ici..."></textarea>

            <button type="submit">
                <span class="submit-icon" aria-hidden="true">
                    <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        xmlns="http://www.w3.org/2000/svg"
                    >
                        <path
                            d="M21 3L10 14"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                        <path
                            d="M21 3L14 21L10 14L3 10L21 3Z"
                            stroke="currentColor"
                            stroke-width="1.8"
                            stroke-linecap="round"
                            stroke-linejoin="round"></path>
                    </svg>
                </span>
                <span>Envoyer le message</span>
            </button>
        </form>

        <section class="contact-details">
            <h2>Coordonnées</h2>

            <div class="contact-cards">
                {
                    contacts.map((item) => (
                        <article class="contact-card">
                            <h3>
                                <span>{item.icon}</span>
                                {item.title}
                            </h3>
                            {item.lines.map((line) => (
                                <p>{line}</p>
                            ))}
                        </article>
                    ))
                }
            </div>
        </section>
    </section>
</Layout>

<style>
    .contact-page {
        max-width: 460px;
        margin: 0 auto;
        padding: 1rem 0.45rem 2rem;
    }

    .contact-header h1 {
        margin: 0;
        font-family: "Ag Body", serif;
        font-size: clamp(2.8rem, 11vw, 4.5rem);
        line-height: 0.95;
        color: #9a6f29;
    }

    .contact-header p {
        margin: 0.2rem 0 1rem;
        font-family: "Ag Body", serif;
        font-size: clamp(1.7rem, 7vw, 2.4rem);
        line-height: 1;
        color: #7a2018;
        font-weight: 700;
    }

    .contact-form {
        display: grid;
        gap: 0.5rem;
        padding: 0.92rem;
        border: 1px solid #a88343;
        border-radius: 0.92rem;
        background: #d8d3c9;
        box-shadow: 0 14px 26px rgba(45, 31, 22, 0.12);
    }

    .contact-form label {
        margin-top: 0.18rem;
        font-family: "Ag Body", serif;
        font-size: 0.95rem;
        color: #2f2a24;
    }

    .contact-form input,
    .contact-form textarea {
        width: 100%;
        border: 1px solid #a24532;
        border-radius: 0.55rem;
        padding: 0.52rem 0.58rem;
        background: #efebe3;
        color: #2e2922;
        font-family: "Ag Body", serif;
        font-size: 0.92rem;
        box-sizing: border-box;
        transition:
            border-color 0.2s ease,
            box-shadow 0.2s ease,
            background-color 0.2s ease;
    }

    .contact-form input:focus,
    .contact-form textarea:focus {
        outline: none;
        border-color: #8b281a;
        background: #f3efe8;
        box-shadow: 0 0 0 3px rgba(139, 40, 26, 0.15);
    }

    .contact-form textarea {
        resize: vertical;
        min-height: 92px;
    }

    .contact-form button {
        width: calc(100% - 28px);
        margin: 0.52rem auto 0;
        border: 0;
        border-radius: 999px;
        padding: 0.68rem 1rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.34rem;
        background: linear-gradient(180deg, #8b281a 0%, #6f1b12 100%);
        color: #f7efe2;
        font-family: "Ag Body", serif;
        font-size: 0.94rem;
        cursor: pointer;
        box-shadow: 0 14px 22px rgba(40, 26, 15, 0.2);
        transition:
            transform 0.18s ease,
            box-shadow 0.18s ease,
            filter 0.18s ease;
    }

    .contact-form button:hover {
        transform: translateY(-1px);
        box-shadow: 0 18px 28px rgba(40, 26, 15, 0.24);
        filter: brightness(1.03);
    }

    .contact-form button:active {
        transform: translateY(0);
    }

    .contact-form button .submit-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 0.72rem;
        height: 0.72rem;
    }

    .contact-form button .submit-icon svg {
        width: 0.72rem;
        height: 0.72rem;
    }

    .contact-details h2 {
        margin: 1.05rem 0 0.62rem;
        font-family: "Ag Body", serif;
        font-size: clamp(2rem, 8vw, 3rem);
        line-height: 1;
        color: #7a2018;
    }

    .contact-cards {
        display: grid;
        gap: 0.5rem;
    }

    .contact-card {
        border: 1px solid #a88343;
        border-radius: 0.72rem;
        background: #d8d3c9;
        padding: 0.58rem 0.65rem;
        box-shadow: 0 8px 14px rgba(45, 31, 22, 0.08);
        transition:
            transform 0.2s ease,
            box-shadow 0.2s ease;
    }

    .contact-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 22px rgba(45, 31, 22, 0.12);
    }

    .contact-card h3 {
        margin: 0 0 0.28rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-family: "Ag Body", serif;
        font-size: 1.05rem;
        color: #9a6f29;
    }

    .contact-card h3 span {
        font-size: 0.95rem;
    }

    .contact-card p {
        margin: 0;
        font-family: "Ag Body", serif;
        font-size: 0.96rem;
        line-height: 1.3;
        color: #352f28;
    }

    @media (min-width: 900px) {
        .contact-page {
            max-width: 1080px;
            padding: 1.5rem 1.2rem 2.8rem;
        }

        .contact-form {
            max-width: 640px;
        }

        .contact-cards {
            grid-template-columns: repeat(3, minmax(0, 1fr));
        }
    }
</style>
