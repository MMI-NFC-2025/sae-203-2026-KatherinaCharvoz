---
import Layout from "../layouts/Layout.astro";
import { getArtistesAlpha, pb } from "../../backend/backend.mjs";

const artistes = await getArtistesAlpha();
console.log(artistes);
---

<Layout title="Accueil">
	<section class="hero">
		<p>Première Edition : Rythmes du Monde</p>
		<h1>Flying Tap Fest</h1>
		<p>Un festival entre ciel et terre</p>
		<p>Du 06 au 07 juin 2026</p>
		<p>Près-la-Rose à Montbéliard</p>
		<a href="/festival" class="btn">Réserver vos billets</a>
	</section>
	<section class="stats">
		<article class="stat-item">
			<p class="stat-value">100+</p>
			<p class="stat-label">Drones pour le show</p>
		</article>
		<article class="stat-item">
			<p class="stat-value">2</p>
			<p class="stat-label">Jours de festival</p>
		</article>
		<article class="stat-item">
			<p class="stat-value">1k</p>
			<p class="stat-label">Spectateurs</p>
		</article>
		<article class="stat-item">
			<p class="stat-value">8+</p>
			<p class="stat-label">Artistes sur scene</p>
		</article>
	</section>
	<section class="explore">
		<h2>Explorez le Festival</h2>
		<p class="explore-sub">Découvrez tout ce que<br>le Flying Tap Fest a à offrir !</p>
		<div class="explore-cards">
			<div class="explore-card">
				<img src="/public/drone_pageaccueil.jpg" alt="Drones" />
				<div class="explore-card-content">
					<h3>Drones</h3>
					<p>Le spectacle de drones sera un moment magique où des centaines de lumières danseront dans le ciel...</p>
					<a href="/festival" class="explore-link">Plus d'information <span>&#8594;</span></a>
				</div>
			</div>
			<div class="explore-card">
				<img src="/public/programme_pageaccueil.jpg" alt="Programme" />
				<div class="explore-card-content">
					<h3>Programme</h3>
					<p>Découvrez notre programmation complète avec plus de 8 artistes sur 2 jours...</p>
					<a href="/festival" class="explore-link">Plus d'information <span>&#8594;</span></a>
				</div>
			</div>
			<div class="explore-card">
				<img src="/public/artistes_pageaccueil.jpg" alt="Artistes" />
				<div class="explore-card-content">
					<h3>Artistes</h3>
					<p>Des légendes des claquettes aux jeunes prodiges, rencontrez tous nos artistes exceptionnels...</p>
					<a href="/festival" class="explore-link">Plus d'information <span>&#8594;</span></a>
				</div>
			</div>
			<div class="explore-card">
				<img src="/public/infos_pratiques_pageaccueil.jpg" alt="Infos Pratiques" />
				<div class="explore-card-content">
					<h3>Infos Pratiques</h3>
					<p>Tarifs, accès, hébergement... Toutes les informations pour préparer votre venue au festival...</p>
					<a href="/festival" class="explore-link">Plus d'information <span>&#8594;</span></a>
				</div>
			</div>
		</div>
	</section>

	<section class="partners">
    <h2>Nos Partenaires</h2>
    <div class="partners-slider">
        <div class="partners-track">
            <img src="/public/partenaires_logo/decathlon_partenaire.jpeg" alt="Decathlon" />
            <img src="/public/partenaires_logo/Pays_de_Montbeliard_partenaire.png" alt="Pays de Montbéliard" />
            <img src="/public/partenaires_logo/moloco-logo_partenaire.png" alt="Le Moloco" />
            
            <img src="/public/partenaires_logo/decathlon_partenaire.jpeg" alt="Decathlon" />
            <img src="/public/partenaires_logo/Pays_de_Montbeliard_partenaire.png" alt="Pays de Montbéliard" />
            <img src="/public/partenaires_logo/moloco-logo_partenaire.png" alt="Le Moloco" />
        </div>
    </div>
	</section>

	<section class="cta">
		<h2>Prêt à vivre<br>l'expérience ?</h2>
		<p>Ne manquez pas l'évènement incontournable de l'été 2026</p>
		<a href="/festival" class="btn">Réserver maintenant</a>
	</section>
<style>
	.hero {
			text-align: center;
			padding: 2rem 2rem;
			text-emphasis-color: #;
			background-image: url("/public/hero_image_tap_dancer.jpg");
			background-size: 100% auto;
			background-repeat: no-repeat;
			min-height: 900px;
			color: white;
			font-family: "Ag Body", serif;
		}
		.btn {
			display: inline-block;
			margin-top: 1rem;
			padding: 0.75rem 1.5rem;
			background-color: #a00c0c;
			color: white;
			text-decoration: none;
			border-radius: 4px;
			transition: background-color 0.3s ease;
		}
		.hero p {
			background: rgba(40, 40, 40, 0.7);
			border-radius: 2rem;
			padding: 0.5rem 1.5rem;
			margin: 1rem auto;
			width: fit-content;
			font-size: 1.1rem;
			font-family: "Ag Body", serif;
		}
		.hero h1 {
			font-family: "Ag Body", serif;
			font-size: 3rem;
			font-weight: bold;
			background: rgba(40, 40, 40, 0.7);
			border-radius: 2rem;
			padding: 0.5rem 2rem;
			margin: 1rem auto;
			width: fit-content;
		}
		.stats {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 3.2rem 2.2rem;
			background: #ebe8e1;
			padding: 3.2rem 2rem;
			max-width: 760px;
			margin: 0 auto;
			border: 1px solid #d8d4cb;
			border-radius: 1.8rem;
		}
		.stat-item {
			text-align: center;
		}
		.stat-value {
			margin: 0;
			line-height: 1;
			font-family: "Ag Body", serif;
			font-size: 4rem;
			font-weight: 700;
			color: #842f22;
		}
		.stat-label {
			margin: 0.45rem 0 0;
			font-family: "Ag Body", serif;
			font-size: 1.9rem;
			line-height: 1.2;
			color: #1f1b18;
		}
		@media (min-width: 900px) {
			.stats {
				max-width: 940px;
				padding: 4.8rem 3.8rem;
				gap: 4.6rem 4rem;
			}
			.stat-value {
				font-size: 4.6rem;
			}
			.stat-label {
				font-size: 2.1rem;
			}
		}
		.explore {
			background: #b3ae9a;
			padding: 2.5rem 0 3rem 0;
			text-align: center;
		}
		.explore h2,
		.partners h2 {
			font-family: 'Ag Body', serif;
			font-size: 2.5rem;
			font-weight: bold;
			margin-bottom: 0.5rem;
		}
		.explore-sub {
			font-family: 'Ag Body', serif;
			font-size: 1.2rem;
			font-weight: 600;
			margin-bottom: 2rem;
		}
		.explore-cards {
			display: flex;
			flex-direction: column;
			gap: 2rem;
			align-items: center;
		}
		.explore-card {
			background: #f5f1eb;
			border-radius: 1.5rem;
			box-shadow: 0 4px 24px rgba(0,0,0,0.08);
			overflow: hidden;
			max-width: 350px;
			width: 100%;
			text-align: left;
		}
		.explore-card img {
			width: 100%;
			height: 140px;
			object-fit: cover;
			border-top-left-radius: 1.5rem;
			border-top-right-radius: 1.5rem;
		}
		.explore-card-content {
			padding: 1.2rem 1.5rem 1.5rem 1.5rem;
		}
		.explore-card-content h3 {
			font-family: 'Ag Body', serif;
			font-size: 1.3rem;
			font-weight: bold;
			margin-bottom: 0.5rem;
		}
		.explore-card-content p {
			font-family: 'Ag Body', serif;
			font-size: 1rem;
			margin-bottom: 1rem;
		}
		.explore-link {
			color: #a00c0c;
			font-weight: bold;
			text-decoration: none;
			font-family: 'Ag Body', serif;
			font-size: 1.05rem;
		}
		@media (min-width: 900px) {
			.explore-cards {
				flex-direction: row;
				justify-content: center;
				gap: 2.5rem;
			}
			.explore-card {
				max-width: 320px;
			}
		}
		@media (min-width: 1024px) {
			.hero {
				min-height: 780px;
				padding: 4.5rem 2rem;
				background-size: cover;
				background-position: center 10%;
			}
			.hero h1 {
				font-size: 4.2rem;
				padding: 0.6rem 2.6rem;
			}
			.hero p {
				font-size: 1.25rem;
			}
			.hero .btn {
				padding: 0.9rem 2.2rem;
				border-radius: 999px;
				font-size: 1.05rem;
			}

			.stats {
				max-width: 940px;
				padding: 4.8rem 3.8rem;
				grid-template-columns: repeat(2, 1fr);
				gap: 4.6rem 4rem;
				margin-top: 3rem;
				margin-bottom: 3rem;
				position: relative;
				z-index: 2;
			}

			.explore {
				padding: 3.5rem 2rem 4rem;
			}
			.explore h2,
			.partners h2 {
				font-size: 3.1rem;
			}
			.explore-sub {
				font-size: 1.35rem;
				margin-bottom: 2.5rem;
			}
			.explore-cards {
				display: grid;
				grid-template-columns: repeat(4, minmax(220px, 1fr));
				gap: 1.4rem;
				max-width: 1260px;
				margin: 0 auto;
				align-items: stretch;
			}
			.explore-card {
				max-width: none;
			}
			.explore-card img {
				height: 170px;
			}

			.partners {
				margin: 0;
				padding: 1.8rem 0;
			}
			.partners h2 {
				margin-bottom: 0.5rem;
			}
			.partners-track img {
				height: 120px;
				margin: 0 2rem;
			}

			.cta {
				padding: 4.4rem 1rem;
			}
			.cta h2 {
				font-size: 2.6rem;
			}
			.cta p {
				font-size: 1.2rem;
			}
		}
		.partners {
			margin: 2rem 0;
			text-align: center;
			background-color: #f9f9f9;
			padding: 1rem 0;
		}
		.partners-slider {
			overflow: hidden;
			position: relative;
			white-space: nowrap;
		}
		.partners-track {
			display: flex;
			animation: scroll 10s linear infinite;
		}
		.partners-track img {
			height: 100px;
			margin: 0 1rem;
			object-fit: contain;
		}
		@keyframes scroll {
			0% {
				transform: translateX(0);
			}
			100% {
				transform: translateX(-50%);
			}
		}
		.cta {
			text-align: center;
			padding: 4.4rem 1.2rem 4.8rem;
			background:
				radial-gradient(120% 80% at 50% 108%, #9d742d 0%, rgba(157, 116, 45, 0.2) 35%, rgba(157, 116, 45, 0) 55%),
				linear-gradient(180deg, #7f1f1c 0%, #7a241b 42%, #8d5d23 100%);
		}
		.cta h2 {
			font-family: "Ag Body", serif;
			font-size: 3.2rem;
			line-height: 1.08;
			font-weight: 700;
			color: #f6efe7;
			margin-bottom: 1.2rem;
		}
		.cta p {
			font-size: 1.8rem;
			line-height: 1.35;
			color: #f3e8dc;
			max-width: 34rem;
			margin: 0 auto 2.4rem;
		}
		.cta .btn {
			padding: 1rem 2.2rem;
			border-radius: 999px;
			background: #f3eee5;
			color: #872c1f;
			font-size: 1.8rem;
			font-weight: 700;
			font-family: "Ag Body", serif;
			border: none;
			box-shadow: 0 10px 24px rgba(0, 0, 0, 0.28);
		}
		.cta .btn:hover {
			background: #ffffff;
			color: #742317;
		}
		@media (max-width: 640px) {
			.cta {
				padding: 3.3rem 1rem 3.6rem;
			}
			.cta h2 {
				font-size: 2.2rem;
			}
			.cta p {
				font-size: 1.35rem;
				max-width: 20rem;
			}
			.cta .btn {
				font-size: 1.35rem;
				padding: 0.85rem 1.6rem;
			}
		}
	</style>
</Layout>
