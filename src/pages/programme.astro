---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import {
    getArtistesAlpha,
    getScenesByName,
    pb,
} from "../../backend/backend.mjs";

const artistes = await getArtistesAlpha();
const scenes = await getScenesByName();
const fallbackImages = [
    "/programme_pageaccueil.jpg",
    "/artistes_pageaccueil.jpg",
    "/hero_image_tap_dancer.jpg",
];

const sceneArtistOrder = {
    "scene decouverte": [
        "j8nriyucmzjtkim",
        "k3je02zet3l6omq",
        "tvwnq35rr932rcr",
        "iq6z8renidcpc7t",
    ],
    "grande scene": [
        "x9be9qq8r4wrgml",
        "5ddozlisgqo03jc",
        "bw4hcnx9yz81hra",
        "nm8abdkh6pknuw6",
    ],
};

function normalizeSceneName(sceneName) {
    return (sceneName || "")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .trim()
        .toLowerCase();
}

function formatHour(value) {
    const date = new Date(value);

    if (Number.isNaN(date.getTime())) {
        return "--:--";
    }

    return new Intl.DateTimeFormat("fr-FR", {
        hour: "2-digit",
        minute: "2-digit",
    }).format(date);
}

function formatDayMonth(value) {
    const date = new Date(value);

    if (Number.isNaN(date.getTime())) {
        return "Date à confirmer";
    }

    return new Intl.DateTimeFormat("fr-FR", {
        day: "2-digit",
        month: "long",
    }).format(date);
}

const artistsById = new Map(artistes.map((artist) => [artist.id, artist]));

const slotsByScene = scenes.reduce((acc, slot) => {
    const sceneName = slot.nom_scene || slot.scene || slot.nom || "";
    const key = normalizeSceneName(sceneName);

    if (!acc[key]) {
        acc[key] = [];
    }

    acc[key].push(slot);
    return acc;
}, {});

for (const key of Object.keys(slotsByScene)) {
    slotsByScene[key].sort(
        (leftSlot, rightSlot) =>
            new Date(leftSlot.date_festival || 0).getTime() -
            new Date(rightSlot.date_festival || 0).getTime(),
    );
}

const programmeEvents = [];

for (const [sceneKey, artistIds] of Object.entries(sceneArtistOrder)) {
    const sceneSlots = slotsByScene[sceneKey] || [];

    artistIds.forEach((artistId, index) => {
        const artist = artistsById.get(artistId);
        const slot = sceneSlots[index];

        if (!artist || !slot) {
            return;
        }

        const dateValue = slot.date_festival;
        const photoField = artist.photo_artiste || artist.image;
        const image = photoField
            ? pb.files.getURL(artist, photoField)
            : fallbackImages[index % fallbackImages.length];

        programmeEvents.push({
            id: artist.id,
            name:
                artist.nom_prenom_pseudo_artiste ||
                artist.nom ||
                artist.name ||
                "Artiste",
            genre: artist.type_de_festival || "Tap",
            horaire: formatHour(dateValue),
            scene: slot.nom_scene || slot.scene || artist.nom_scene || "Scène",
            dateLabel: formatDayMonth(dateValue),
            dateValue: new Date(dateValue || 0).getTime(),
            image,
        });
    });
}

programmeEvents.sort(
    (leftEvent, rightEvent) => leftEvent.dateValue - rightEvent.dateValue,
);

const uniqueGenres = Array.from(
    new Set(programmeEvents.map((event) => event.genre)),
);
const uniqueHours = Array.from(
    new Set(programmeEvents.map((event) => event.horaire)),
);
const uniqueScenes = Array.from(
    new Set(programmeEvents.map((event) => event.scene)),
);

const filters = {
    genres: ["Tous les genres", ...uniqueGenres],
    horaires: ["Tous les horaires", ...uniqueHours],
    scenes: ["Toutes les scènes", ...uniqueScenes],
};
---

<Layout title="Programme">
    <Header
        title="Le Programme"
        subtitle="Découvrez tous les événements"
        showEvents={false}
    />

    <section class="programme-page">
        <h1 class="programme-title">Programme</h1>

        <a
            href="/"
            class="pdf-btn"
            aria-label="Télécharger le programme en PDF"
        >
            <span class="pdf-icon">⇩</span>
            Télécharger le programme en PDF
        </a>

        <div class="filters-card">
            <h2>Filtres</h2>

            <div class="filter-group">
                <label for="genre">Genre</label>
                <select id="genre" name="genre">
                    {
                        filters.genres.map((option) => (
                            <option value={option}>{option}</option>
                        ))
                    }
                </select>
            </div>

            <div class="filter-group">
                <label for="horaire">Horaire</label>
                <select id="horaire" name="horaire">
                    {
                        filters.horaires.map((option) => (
                            <option value={option}>{option}</option>
                        ))
                    }
                </select>
            </div>

            <div class="filter-group">
                <label for="scene">Scène</label>
                <select id="scene" name="scene">
                    {
                        filters.scenes.map((option) => (
                            <option value={option}>{option}</option>
                        ))
                    }
                </select>
            </div>
        </div>

        <div class="events-grid">
            {
                programmeEvents.map((event) => (
                    <article class="event-card">
                        <img
                            src={event.image}
                            alt={`Programme ${event.name}`}
                        />
                        <div class="event-content">
                            <h3>{event.dateLabel}</h3>
                            <p>{event.name}</p>
                            <p>{event.genre}</p>
                            <p>Horaire : {event.horaire}</p>
                            <p>Scène : {event.scene}</p>
                            <a href={`/${event.id}`} class="event-link">
                                Plus d'information <span>&#8594;</span>
                            </a>
                        </div>
                    </article>
                ))
            }
        </div>
    </section>
</Layout>

<style>
    .programme-page {
        max-width: 1120px;
        margin: 0 auto;
        padding: 1.5rem 1rem 2.4rem;
    }

    .programme-title {
        margin: 0 0 1.1rem;
        color: #9a6f29;
        font-family: "Ag Body", serif;
        font-size: clamp(3rem, 8vw, 5rem);
        line-height: 1;
    }

    .pdf-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        margin: 0 0 1.5rem;
        background: #8b271b;
        color: #f7efe3;
        text-decoration: none;
        border-radius: 999px;
        padding: 0.85rem 1.25rem;
        font-family: "Ag Body", serif;
        font-size: clamp(1.25rem, 3.2vw, 1.8rem);
        font-weight: 700;
        box-shadow: 0 5px 14px rgba(90, 28, 18, 0.18);
    }

    .pdf-icon {
        font-size: 1em;
        line-height: 1;
    }

    .filters-card {
        background: #1e1f22;
        border-radius: 1.25rem;
        padding: 1rem 1.05rem 1.15rem;
        color: #d2be8a;
        max-width: 560px;
        margin-bottom: 1.8rem;
    }

    .filters-card h2 {
        margin: 0 0 0.9rem;
        font-family: "Ag Body", serif;
        font-size: clamp(1.25rem, 3.4vw, 1.8rem);
        font-weight: 700;
    }

    .filter-group {
        margin-bottom: 0.85rem;
    }

    .filter-group:last-child {
        margin-bottom: 0;
    }

    .filter-group label {
        display: block;
        color: #dbc8a1;
        margin-bottom: 0.3rem;
        font-family: "Ag Body", serif;
        font-size: clamp(1.05rem, 2.6vw, 1.35rem);
    }

    .filter-group select {
        width: 100%;
        height: 2.05rem;
        border: none;
        border-radius: 999px;
        padding: 0 2.35rem 0 0.75rem;
        background: #f0ebe3;
        color: #8d7646;
        font-family: "Ag Body", serif;
        font-size: clamp(1rem, 2.4vw, 1.25rem);
        appearance: none;
        background-image:
            linear-gradient(45deg, transparent 50%, #8d7646 50%),
            linear-gradient(135deg, #8d7646 50%, transparent 50%);
        background-position:
            calc(100% - 1.05rem) 52%,
            calc(100% - 0.75rem) 52%;
        background-size:
            0.38rem 0.38rem,
            0.38rem 0.38rem;
        background-repeat: no-repeat;
    }

    .events-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    .event-card {
        background: #f7f2ea;
        border-radius: 1rem;
        overflow: hidden;
        box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
    }

    .event-card img {
        width: 100%;
        height: 165px;
        object-fit: cover;
        display: block;
    }

    .event-content {
        padding: 0.9rem 1rem 1.05rem;
    }

    .event-content h3 {
        margin: 0 0 0.4rem;
        color: #7d281b;
        font-family: "Ag Body", serif;
        font-size: 1.3rem;
        font-weight: 800;
    }

    .event-content p {
        margin: 0.2rem 0;
        color: #2b2722;
        font-family: "Ag Body", serif;
    }

    .event-link {
        display: inline-block;
        margin-top: 0.55rem;
        color: #8b271b;
        text-decoration: none;
        font-weight: 700;
        font-family: "Ag Body", serif;
    }

    @media (min-width: 900px) {
        .programme-page {
            padding: 2rem 1.6rem 2.8rem;
        }

        .pdf-btn {
            padding: 0.95rem 1.55rem;
        }

        .filters-card {
            max-width: 640px;
            padding: 1.25rem 1.2rem;
        }

        .events-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }
</style>
