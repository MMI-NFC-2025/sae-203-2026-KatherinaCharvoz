---
import Layout from "../../layouts/Layout.astro";
import {
    getArtistesAlpha,
    getScenesByName,
    pb,
} from "../../../backend/backend.mjs";
import { artistScheduleById } from "../../data/artistSchedule";

type SceneRecord = {
    image_scene?: string;
    scene?: string;
    nom?: string;
    nom_scene?: string;
    date_festival?: string;
    [key: string]: unknown;
};

type ArtistRecord = {
    id: string;
    nom_prenom_pseudo_artiste?: string;
    nom?: string;
    name?: string;
    nom_scene?: string;
    scene?: string;
    photo_artiste?: string;
    type_de_festival?: string;
    [key: string]: unknown;
};

type ScheduledArtist = {
    slot: SceneRecord;
    artist: ArtistRecord | null;
    dayLabel: string;
    dateLabel: string;
    timeLabel: string;
};

const sceneArtistOrder: Record<string, string[]> = {
    "scene decouverte": [
        "j8nriyucmzjtkim",
        "k3je02zet3l6omq",
        "iq6z8renidcpc7t",
        "tvwnq35rr932rcr",
    ],
    "grande scene": [
        "x9be9qq8r4wrgml",
        "5ddozlisgqo03jc",
        "bw4hcnx9yz81hra",
        "nm8abdkh6pknuw6",
    ],
};

function normalizeSceneName(sceneName: string) {
    return (sceneName || "")
        .normalize("NFD")
        .replace(/[\u0300-\u036f]/g, "")
        .trim()
        .toLowerCase();
}

function slugifySceneName(sceneName: string) {
    return normalizeSceneName(sceneName)
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-|-$/g, "");
}

function getSceneSubtitle(sceneName: string) {
    const normalizedName = normalizeSceneName(sceneName);

    if (normalizedName.includes("grande")) {
        return "Sous le grand chapiteau";
    }

    if (normalizedName.includes("decouverte")) {
        return "Dans l'espace découverte du festival";
    }

    return "Au coeur du festival";
}

function getFallbackSceneImage(sceneName: string) {
    const normalizedName = normalizeSceneName(sceneName);

    if (normalizedName.includes("grande")) {
        return "/programme_pageaccueil.jpg";
    }

    if (normalizedName.includes("decouverte")) {
        return "/artistes_pageaccueil.jpg";
    }

    return "/hero_image_tap_dancer.jpg";
}

function formatDayLabel(value: string | number | Date | undefined) {
    const date = new Date(value);

    if (Number.isNaN(date.getTime())) {
        return "Programmation";
    }

    return new Intl.DateTimeFormat("fr-FR", {
        day: "2-digit",
        month: "long",
        year: "numeric",
    }).format(date);
}

function formatDateLabel(value: string | number | Date | undefined) {
    const date = new Date(value);

    if (Number.isNaN(date.getTime())) {
        return "Date à confirmer";
    }

    return new Intl.DateTimeFormat("fr-FR", {
        day: "2-digit",
        month: "long",
        year: "numeric",
    }).format(date);
}

function formatTimeLabel(value: string | number | Date | undefined) {
    const date = new Date(value);

    if (Number.isNaN(date.getTime())) {
        return "Horaire à confirmer";
    }

    return new Intl.DateTimeFormat("fr-FR", {
        hour: "2-digit",
        minute: "2-digit",
    }).format(date);
}

export async function getStaticPaths() {
    const scenes = await getScenesByName();
    const uniqueScenes = Array.from(
        scenes
            .reduce((sceneMap, scene) => {
                const name =
                    scene.scene || scene.nom || scene.nom_scene || "Scène";
                const key = normalizeSceneName(name);

                if (!sceneMap.has(key)) {
                    sceneMap.set(key, name);
                }

                return sceneMap;
            }, new Map())
            .values(),
    );

    return uniqueScenes.map((sceneName) => ({
        params: { id: slugifySceneName(sceneName) },
        props: { sceneName },
    }));
}

const { sceneName } = Astro.props;
const allScenes = await getScenesByName();
const allArtists = await getArtistesAlpha();
const normalizedCurrentScene = normalizeSceneName(sceneName);

const sceneSlots = (allScenes as SceneRecord[])
    .filter(
        (scene) =>
            normalizeSceneName(
                scene.scene || scene.nom || scene.nom_scene || "",
            ) === normalizedCurrentScene,
    )
    .sort(
        (leftSlot, rightSlot) =>
            new Date(leftSlot.date_festival || 0).getTime() -
            new Date(rightSlot.date_festival || 0).getTime(),
    );

const artists = (allArtists as ArtistRecord[]).filter(
    (artist) =>
        normalizeSceneName(artist.nom_scene || artist.scene || "") ===
        normalizedCurrentScene,
);

const preferredArtistIds = sceneArtistOrder[normalizedCurrentScene] || [];

artists.sort((leftArtist, rightArtist) => {
    const leftIndex = preferredArtistIds.indexOf(leftArtist.id);
    const rightIndex = preferredArtistIds.indexOf(rightArtist.id);

    if (leftIndex === -1 && rightIndex === -1) {
        return 0;
    }

    if (leftIndex === -1) {
        return 1;
    }

    if (rightIndex === -1) {
        return -1;
    }

    return leftIndex - rightIndex;
});

const sceneWithImage = sceneSlots.find((scene) => scene.image_scene);

const heroImage = sceneWithImage?.image_scene
    ? pb.files.getURL(sceneWithImage, sceneWithImage.image_scene)
    : getFallbackSceneImage(sceneName);

const scheduledArtists: ScheduledArtist[] = sceneSlots.map((slot, index) => ({
    slot,
    artist: artists[index] || null,
    dayLabel: (() => {
        const artist = artists[index] || null;
        const schedule = artist ? artistScheduleById[artist.id] : null;
        return schedule?.date || formatDayLabel(slot.date_festival);
    })(),
    dateLabel: (() => {
        const artist = artists[index] || null;
        const schedule = artist ? artistScheduleById[artist.id] : null;
        return schedule?.date || formatDateLabel(slot.date_festival);
    })(),
    timeLabel: (() => {
        const artist = artists[index] || null;
        const schedule = artist ? artistScheduleById[artist.id] : null;
        return schedule?.horaire || formatTimeLabel(slot.date_festival);
    })(),
}));

const groupedArtists = Array.from(
    scheduledArtists.reduce((dayMap, entry) => {
        if (!entry.artist) {
            return dayMap;
        }

        if (!dayMap.has(entry.dayLabel)) {
            dayMap.set(entry.dayLabel, []);
        }

        dayMap.get(entry.dayLabel).push(entry);
        return dayMap;
    }, new Map<string, ScheduledArtist[]>()),
).map(([dayLabel, entries]) => ({ dayLabel, entries }));
---

<Layout title={sceneName}>
    <section class="scene-detail-page">
        <a class="back-link" href="/scenes"
            >&larr; Retour à la liste des scènes</a
        >

        <header class="scene-hero">
            <div class="scene-hero-copy">
                <h1>{sceneName}</h1>
                <p class="scene-subtitle">{getSceneSubtitle(sceneName)}</p>
            </div>

            <img src={heroImage} alt={sceneName} loading="eager" />
        </header>

        <section class="artists-section">
            <h2>Artistes Présents</h2>

            {
                groupedArtists.map((group) => (
                    <div class="day-group">
                        <h3>{group.dayLabel}</h3>

                        <div class="artists-list">
                            {group.entries.map((entry: ScheduledArtist) => {
                                const { artist, dateLabel, timeLabel } = entry;
                                const artistName =
                                    artist.nom_prenom_pseudo_artiste ||
                                    artist.nom ||
                                    artist.name ||
                                    "Artiste";
                                const artistType =
                                    artist.type_de_festival || "Performance";
                                const artistImage = artist.photo_artiste
                                    ? pb.files.getURL(
                                          artist,
                                          artist.photo_artiste,
                                      )
                                    : "/hero_image_tap_dancer.jpg";

                                return (
                                    <a
                                        class="artist-card"
                                        href={`/${artist.id}`}
                                    >
                                        <img
                                            src={artistImage}
                                            alt={artistName}
                                            loading="lazy"
                                        />
                                        <div class="artist-content">
                                            <h4>{artistName}</h4>
                                            <p class="artist-type">
                                                {artistType}
                                            </p>
                                            <div class="artist-meta">
                                                <span>
                                                    <strong>Horaire :</strong>{" "}
                                                    {timeLabel}
                                                </span>
                                                <span>
                                                    <strong>Date :</strong>{" "}
                                                    {dateLabel}
                                                </span>
                                            </div>
                                        </div>
                                    </a>
                                );
                            })}
                        </div>
                    </div>
                ))
            }
        </section>
    </section>
</Layout>

<style>
    .scene-detail-page {
        max-width: 410px;
        margin: 0 auto;
        padding: 0.75rem 0.42rem 1.8rem;
    }

    .back-link {
        display: inline-flex;
        margin-bottom: 0.4rem;
        font-family: "Ag Body", serif;
        font-size: 0.68rem;
        line-height: 1;
        color: #6f675d;
        text-decoration: none;
    }

    .scene-hero {
        display: grid;
        gap: 0.7rem;
        margin-bottom: 1rem;
    }

    .scene-hero-copy h1 {
        margin: 0 0 0.08rem;
        font-family: "Ag Body", serif;
        font-size: clamp(2.75rem, 13vw, 4.5rem);
        line-height: 0.9;
        color: #9a6f29;
    }

    .scene-subtitle {
        margin: 0;
        font-family: "Ag Body", serif;
        font-size: clamp(0.88rem, 3.6vw, 1.12rem);
        line-height: 1.1;
        font-weight: 700;
        color: #7a2018;
    }

    .scene-hero img {
        width: 100%;
        height: 250px;
        object-fit: cover;
        border-radius: 0;
        box-shadow: none;
    }

    .artists-section h2 {
        margin: 0.6rem 0 0.55rem;
        font-family: "Ag Body", serif;
        font-size: clamp(1.28rem, 5.6vw, 1.9rem);
        line-height: 1;
        color: #7a2018;
    }

    .day-group {
        margin-bottom: 0.78rem;
    }

    .day-group h3 {
        margin: 0 0 0.3rem;
        font-family: "Ag Body", serif;
        font-size: clamp(0.62rem, 2.4vw, 0.78rem);
        line-height: 1.1;
        color: #6a6358;
        text-transform: capitalize;
    }

    .artists-list {
        display: grid;
        gap: 0.42rem;
    }

    .artist-card {
        display: grid;
        grid-template-columns: 72px 1fr;
        gap: 0.48rem;
        align-items: stretch;
        padding: 0.38rem;
        background: #d6d1c7;
        border-radius: 0.52rem;
        text-decoration: none;
        box-shadow: none;
    }

    .artist-card img {
        width: 100%;
        height: 100%;
        min-height: 78px;
        object-fit: cover;
        border-radius: 0.45rem;
    }

    .artist-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.06rem;
    }

    .artist-content h4 {
        margin: 0;
        font-family: "Ag Body", serif;
        font-size: clamp(0.8rem, 3.1vw, 1rem);
        line-height: 1.05;
        color: #a98034;
    }

    .artist-type {
        margin: 0;
        font-family: "Ag Body", serif;
        font-size: 0.6rem;
        color: #8b2a1e;
    }

    .artist-meta {
        display: grid;
        gap: 0.02rem;
        font-family: "Ag Body", serif;
        font-size: 0.56rem;
        line-height: 1.15;
        color: #554d44;
    }

    .artist-meta span {
        display: block;
    }

    .artist-meta strong {
        color: #7a2018;
        font-weight: 700;
    }

    @media (min-width: 900px) {
        .scene-detail-page {
            max-width: 1100px;
            padding: 1.8rem 1.3rem 2.6rem;
        }

        .back-link {
            font-size: 1rem;
            color: #7a2018;
            margin-bottom: 1rem;
        }

        .scene-hero {
            grid-template-columns: minmax(0, 1fr) minmax(380px, 500px);
            align-items: start;
            gap: 1.4rem;
        }

        .scene-hero img {
            height: 440px;
            border-radius: 1.6rem;
            box-shadow: 0 20px 35px rgba(0, 0, 0, 0.12);
        }

        .artists-section h2 {
            margin: 0 0 1rem;
            font-size: clamp(2.2rem, 8vw, 4rem);
            color: #9a6f29;
        }

        .day-group h3 {
            font-size: clamp(1rem, 3.5vw, 1.4rem);
            margin: 0 0 0.6rem;
            color: #7a2018;
        }

        .artists-list {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.85rem;
        }

        .artist-card {
            grid-template-columns: 108px 1fr;
            gap: 0.8rem;
            padding: 0.7rem;
            border-radius: 1.1rem;
        }

        .artist-card img {
            min-height: 118px;
            border-radius: 0.95rem;
        }

        .artist-content h4 {
            font-size: clamp(1.1rem, 2.2vw, 1.5rem);
        }

        .artist-type {
            font-size: 0.92rem;
        }

        .artist-meta {
            font-size: 0.9rem;
            gap: 0.12rem;
        }
    }
</style>
